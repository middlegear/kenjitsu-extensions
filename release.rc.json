{
    "branches": [
        {
            "name": "dev",
            "channel": "ci",
            "prerelease": "ci"
        },
        {
            "name": "main",
            "channel": "stable"
        }
    ],
    "plugins": [
        [
            "@semantic-release/commit-analyzer",
            {
                "preset": "angular",
                "releaseRules": [
                    {
                        "type": "none",
                        "release": "patch"
                    }
                ],
                "parserOpts": {
                    "noteKeywords": []
                }
            }
        ],
        [
            "@semantic-release/release-notes-generator",
            {
                "preset": "angular"
            }
        ],
        [
            "@semantic-release/changelog"
        ],
        [
            "@semantic-release/npm"
        ],
        [
            "@semantic-release/github"
        ]
    ]
}