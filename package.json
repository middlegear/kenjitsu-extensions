{
  "name": "hakai-extensions",
  "version": "0.0.0-development",
  "description": "scraper package serving anime, movies and tv media infomation",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "module": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "pnpm build && node dist/main.js",
    "commit": "pnpm lint && cz",
    "test-jikan": "vitest jikan.test.ts   --config vitest.config.ts",
    "test-anilist": "vitest anilist.test.ts  --config vitest.config.ts",
    "test-hianime": "vitest hianime.test.ts  --config vitest.config.ts",
    "test-kaido": "vitest kaido.test.ts  --config vitest.config.ts",
    "test-flixhq": "vitest flixhq.test.ts --config vitest.config.ts",
    "test-tmdb": "vitest tmdb.test.ts --config vitest.config.ts",
    "test-himovies": "vitest himovies.test.ts --config vitest.config.ts",
    "test-animepahe": "vitest animepahe.test.ts --config vitest.config.ts",
    "test": "vitest  --config vitest.config.ts",
    "lint": "tsc",
    "ci": "tsc && pnpm test && pnpm run build",
    "format": "prettier --write .",
    "semantic-release": "semantic-release --branches main"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "anime",
    "scraper",
    "movies",
    "tv"
  ],
  "author": "middlegear",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/middlegear/hakai-extensions"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/middlegear/hakai-extensions",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^24.7.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "prettier": "^3.6.2",
    "semantic-release": "^24.2.9",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "got-scraping": "^4.1.2",
    "header-generator": "^2.1.74"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}