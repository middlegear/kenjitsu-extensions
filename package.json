{
  "name": "kenjitsu-extensions",
  "version": "0.0.0-development",
  "description": "A lightweight Node.js scraper that extracts video sources from streaming sites",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "module": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "pnpm build && node dist/main.js",
    "test": "vitest  --config vitest.config.ts",
    "lint": "tsc",
    "ci": "tsc && pnpm test && pnpm run build",
    "format": "prettier --write .",
    "semantic-release": "semantic-release --branches main"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "anime",
    "scraper",
    "movies",
    "tv"
  ],
  "author": "middlegear",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/middlegear/kenjitsu-extensions"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/middlegear/kenjitsu-extensions",
  "devDependencies": {
    "@types/node": "^24.10.13",
    "prettier": "^3.8.1",
    "semantic-release": "^24.2.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "got-scraping": "^4.2.0"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}